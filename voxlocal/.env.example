# Copier ce fichier en .env et remplir. NE JAMAIS committer .env.

# --- LLM ---
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# --- Voix / téléphonie (Vapi) ---
VAPI_API_KEY=
# Twilio (provisioning numéro FR via regulatory bundle)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# --- Mémoire (mcp-memory) ---
# Racine des documents de connaissance (par défaut: dossier voxlocal/)
VOXLOCAL_MEMORY_PATH=

# --- Base & secrets (phases ultérieures) ---
SUPABASE_URL=
SUPABASE_KEY=
